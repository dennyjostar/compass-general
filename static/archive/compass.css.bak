/* compass.css (v36.0) - 나침반 디자인 */
.compass-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 8px;
}

.compass-wrapper {
    position: relative;
    width: 140px;
    height: 140px;
}

.compass-body {
    position: absolute;
    width: 100%;
    height: 100%;
    will-change: transform;
}

.compass-svg {
    width: 100%;
    height: 100%;
    display: block;
}